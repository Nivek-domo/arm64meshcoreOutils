# This file serves as an example for environment variables needed for the application.
# Users can copy this file and rename it to .env to configure their environment.

# Database configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# Node-RED configuration
NODERED_USER=your_nodered_user
NODERED_PORT=1880

# Python configuration
PYTHON_ENV=your_python_environment

# Additional configurations can be added as needed.